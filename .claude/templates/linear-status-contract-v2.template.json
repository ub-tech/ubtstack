{
  "version": 2,
  "default_status": "Todo",
  "statuses": ["Backlog", "Todo", "In Progress", "Human Review", "Rework", "Merging", "Done"],
  "custom_states_required": ["Rework", "Human Review", "Merging"],
  "transitions": {
    "Backlog": {
      "symphony": ["Todo"]
    },
    "Todo": {
      "symphony": ["In Progress", "Rework"]
    },
    "In Progress": {
      "symphony": ["Human Review", "Rework"]
    },
    "Human Review": {
      "claude": ["Merging", "Rework"]
    },
    "Merging": {
      "symphony": ["Done", "Rework"]
    },
    "Rework": {
      "symphony": ["Todo", "In Progress"]
    }
  },
  "outcomes": {
    "planning_import":     { "target_status": "Todo",         "actor": "symphony" },
    "execution_start":     { "target_status": "In Progress",  "actor": "symphony" },
    "validation_pass":     { "target_status": "Human Review",  "actor": "symphony" },
    "validation_fail":     { "target_status": "Rework",        "actor": "symphony" },
    "claude_review_pass":  { "target_status": "Merging",       "actor": "claude" },
    "claude_review_fail":  { "target_status": "Rework",        "actor": "claude" },
    "merge_complete":      { "target_status": "Done",           "actor": "symphony" },
    "replan_or_retry":     { "target_status": "Todo",           "actor": "symphony" }
  }
}
